# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- Secrets / credentials ---

# Environment files
.env
.env.local
.env.*.local
.env.*
# Keep a sanitised template tracked if the project adds one.
!.env.example

# Generic secret-bearing material
*.pem
*.key
*.p8                  # APNs auth key
*.p12                 # PKCS#12 bundle
*.jks                 # Java keystore
*.keystore
credentials.json
service-account*.json
*-service-account.json

# Firebase per-project scaffold — regenerated by `flutterfire configure`
# on each dev's machine. API keys embedded are safe in mobile binaries
# but conventionally kept out of VCS so forks do not hit the wrong project.
**/google-services.json
**/GoogleService-Info.plist
firebase.json
.firebaserc

# Android app signing
android/key.properties
**/debug.keystore
**/release.keystore

# iOS CocoaPods
ios/Pods/
# Podfile.lock is usually tracked (pinned pod versions); comment the
# next line out only if your workflow needs to regenerate it per-dev.
# ios/Podfile.lock
